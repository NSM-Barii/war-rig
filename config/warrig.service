[Unit]
Description=WarRig Wardriving Rig
After=network.target bluetooth.target
# prevent system hostapd/dnsmasq from fighting us
Conflicts=hostapd.service

[Service]
Type=simple
User=root
ExecStart=/home/pi/war-rig/scripts/start.sh
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
